modules = ["python-3.12"]
[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["mysql80", "p7zip"]

[userenv]

[userenv.shared]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Import"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "MySQL Server"

[[workflows.workflow]]
name = "Run Import"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/run_import.sh"

[[workflows.workflow]]
name = "MySQL Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/mysql_server.sh"

[workflows.workflow.metadata]
outputType = "console"
